# ─── Volume 路徑設定 ───────────────────────────────────
# 主機端備份儲存路徑
HOST_BACKUP_PATH=/mnt/upload/db-backup
# 主機端日誌儲存路徑
HOST_LOG_PATH=/mnt/upload/db-backup/logs
# 容器內備份路徑 (預設，可於每個DB指定覆蓋)
CONTAINER_BACKUP_PATH=/backup
# 容器內日誌路徑 (預設)
CONTAINER_LOG_PATH=/logs

# ─── 基本設定 ─────────────────────────────────────────
# 容器時區設定
TZ=Asia/Taipei
# db-backup 內部排程時區
TIMEZONE=Asia/Taipei
# 是否啟用容器監控功能
CONTAINER_ENABLE_MONITORING=FALSE
# 同時執行的備份任務數量 (建議設為1避免資源競爭)
BACKUP_JOB_CONCURRENCY=1

# ─── 通知設定 (可選) ───────────────────────────────────
# 是否啟用通知功能
ENABLE_NOTIFICATIONS=TRUE
# 通知類型 (CUSTOM EMAIL MATRIX MATTERMOST ROCKETCHAT)
NOTIFICATION_TYPE=EMAIL
# SMTP 伺服器位址
SMTP_HOST=smtp-relay.gmail.com
# SMTP 連接埠
SMTP_PORT=587
# 寄件者信箱
MAIL_FROM=db-backup@datarget.com
# 收件者信箱
MAIL_TO=admin@datarget.com

# ─── 全域預設設定 ─────────────────────────────────────
# 備份儲存系統 (FILESYSTEM/S3/blobxfer)
DEFAULT_BACKUP_LOCATION=FILESYSTEM
# 是否產生 latest symlink 指向最新備份
DEFAULT_CREATE_LATEST_SYMLINK=FALSE
# 壓縮方式 (Gzip GZ, Bzip2 BZ, XZip XZ, ZSTD ZSTD or none NONE)
DEFAULT_COMPRESSION=ZSTD
# 壓縮等級 (1-9, 數字越高壓縮率越高但速度越慢)
DEFAULT_COMPRESSION_LEVEL=6
# 備份保留時間 (分鐘)
DEFAULT_CLEANUP_TIME=10080
# 日誌等級 (INFO NOTICE ERROR WARN DEBUG)
DEFAULT_LOG_LEVEL=INFO
# 是否備份全域物件 (roles/extensions/tablespaces等)
DEFAULT_BACKUP_GLOBALS=TRUE
DEFAULT_SIZE_VALUE=megabytes
# 備份路徑，未指定預設為/backup，指定別的路徑避免某個Job將整個backup路徑clean up
DEFAULT_FILESYSTEM_PATH=/backup/default

# ─── DB01 PostgreSQL 設定 ─────────────────────────────
# 備份檔案儲存路徑 (容器內路徑)
DB01_FILESYSTEM_PATH=/backup/db01
# 資料庫類型 (pgsql/mysql/mongodb等)
DB01_TYPE=pgsql
# PostgreSQL 主機位址
DB01_HOST=your-postgres-host
# PostgreSQL 連接埠
DB01_PORT=5432
# PostgreSQL 使用者名稱 (建議使用具備備份權限的專用帳號)
DB01_USER=postgres
# PostgreSQL 密碼
DB01_PASS=your-password
# 要備份的資料庫名稱 (ALL=全部資料庫，或指定特定資料庫名稱)
DB01_NAME=ALL
# 是否將每個資料庫分別儲存為獨立檔案
DB01_SPLIT_DB=TRUE
# 備份執行時間 (cron格式: 分 時 日 月 週，或 +數字表示N分鐘後執行一次)
# 範例: "30 9 * * 6" = 每週六 09:30, "+1" = 1分鐘後
DB01_BACKUP_BEGIN=+1
