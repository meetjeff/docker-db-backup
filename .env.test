# ─── Volume ────────────────────────────────────────
HOST_BACKUP_PATH=/mnt/nas-114/upload/db-backup
HOST_LOG_PATH=/mnt/nas-114/upload/db-backup/logs
CONTAINER_BACKUP_PATH=/backup
CONTAINER_LOG_PATH=/logs

# ─── Basic ─────────────────────────────────────────
TZ=Asia/Taipei
TIMEZONE=Asia/Taipei
CONTAINER_ENABLE_MONITORING=FALSE
BACKUP_JOB_CONCURRENCY=1

# ─── Notification ──────────────────────────────────
ENABLE_NOTIFICATIONS=TRUE
NOTIFICATION_TYPE=EMAIL
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
MAIL_FROM=db-backup@datarget.com
MAIL_TO=jeff.hsu@datarget.com

# ─── Global Default ────────────────────────────────
DEFAULT_BACKUP_LOCATION=FILESYSTEM
DEFAULT_CREATE_LATEST_SYMLINK=FALSE
DEFAULT_COMPRESSION=ZSTD
DEFAULT_COMPRESSION_LEVEL=6
DEFAULT_CLEANUP_TIME=10079
DEFAULT_LOG_LEVEL=INFO
DEFAULT_BACKUP_GLOBALS=TRUE
DEFAULT_SIZE_VALUE=megabytes
DEFAULT_FILESYSTEM_PATH=/backup/default

